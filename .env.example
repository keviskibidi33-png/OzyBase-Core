# shell: bash
# shellcheck disable=SC2034

# Deployment configuration
PORT="5342"
SITE_URL="https://api.example.com"
APP_DOMAIN="example.com"

# Security & Performance
ALLOWED_ORIGINS="https://app.example.com,https://api.example.com"
# JWT Secret Key
JWT_SECRET=replace-with-a-64-byte-random-secret
# Service role key for server-to-server integration (optional but recommended)
SERVICE_ROLE_KEY=replace-with-a-long-random-service-role-key

# SMTP Configuration (Compatible with cPanel, AWS SES, Resend, SendGrid)
# Leave empty to use LogMailer (console only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="noreply@example.com"
RATE_LIMIT_RPS="50"
RATE_LIMIT_BURST="100"
BODY_LIMIT="10M"

# Database (PostgreSQL)
DATABASE_URL="postgres://ozyuser:replace-with-strong-password@localhost:5432/Ozydb?sslmode=verify-full"
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="ozyuser"
DB_PASSWORD="replace-with-strong-password"
DB_NAME="Ozydb"
DB_SSLMODE="verify-full"

# Application Settings
DEBUG="false"
OZY_STRICT_SECURITY="false"
INITIAL_ADMIN_EMAIL=""
INITIAL_ADMIN_PASSWORD=""

# Coolify / Managed Postgres (recommended in production)
# Prefer this single URL when running docker-compose.coolify.yml
# Example:
# DATABASE_URL="postgres://user:pass@host:5432/dbname?sslmode=require"
DATABASE_URL=""

# Install-to-play behavior:
# - If JWT_SECRET is empty, OzyBase auto-generates and stores it in .ozy_secret.
# - If ALLOWED_ORIGINS is empty, OzyBase auto-derives safe defaults from SITE_URL/APP_DOMAIN.
# - In Coolify, only DATABASE_URL + SITE_URL + APP_DOMAIN are required.
# - In docker-compose.install.yml, DATABASE_URL is auto-built from DB_USER/DB_PASSWORD/DB_NAME.
