# shell: bash
# shellcheck disable=SC2034

# Deployment configuration
PORT="5342"
SITE_URL="http://localhost:5342"
APP_DOMAIN="localhost"

# Security & Performance
ALLOWED_ORIGINS="http://localhost:5342,http://localhost:3000"
# JWT Secret Key
JWT_SECRET=super-secret-key-change-it

# SMTP Configuration (Compatible with cPanel, AWS SES, Resend, SendGrid)
# Leave empty to use LogMailer (console only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="noreply@yourdomain.com"
RATE_LIMIT_RPS="50"
RATE_LIMIT_BURST="100"
BODY_LIMIT="10M"

# Database (PostgreSQL)
DATABASE_URL="postgres://ozyuser:ozypassword123@localhost:5432/Ozydb?sslmode=disable"
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="ozyuser"
DB_PASSWORD="ozypassword123"
DB_NAME="Ozydb"
DB_SSLMODE="disable"

# Application Settings
DEBUG="true"
