PORT=8090
OZY_DEPLOYMENT_PROFILE=install_to_play
DEBUG=false
OZY_STRICT_SECURITY=true
SITE_URL=https://api.example.com
APP_DOMAIN=example.com
ALLOWED_ORIGINS=https://example.com,https://app.example.com

JWT_SECRET=replace-with-a-64-byte-random-secret
ANON_KEY=replace-with-a-stable-publishable-key
SERVICE_ROLE_KEY=replace-with-a-stable-secret-key

DATABASE_URL=postgres://ozybase:replace-with-a-strong-password@db:5432/ozybase?sslmode=require
DB_POOLER_URL=

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=20
OZY_SQL_EDITOR_MAX_ROWS=1000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

OZY_STORAGE_PROVIDER=local
OZY_STORAGE_FALLBACK_LOCAL=true
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=false

OZY_REALTIME_BROKER=local
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0
OZY_REALTIME_CHANNEL=ozy_events_cluster
