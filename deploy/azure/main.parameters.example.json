{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "containerImage": {
      "value": "ghcr.io/xangel0s/ozybase:latest"
    },
    "containerCpu": {
      "value": 1
    },
    "containerMemory": {
      "value": "2Gi"
    },
    "minReplicas": {
      "value": 1
    },
    "maxReplicas": {
      "value": 3
    },
    "siteUrl": {
      "value": "https://api.example.com"
    },
    "appDomain": {
      "value": "example.com"
    },
    "allowedOrigins": {
      "value": "https://example.com,https://app.example.com"
    },
    "postgresAdminLogin": {
      "value": "ozyadmin"
    },
    "postgresAdminPassword": {
      "value": "replace-me"
    },
    "postgresDbName": {
      "value": "ozybase"
    },
    "jwtSecret": {
      "value": "replace-me-with-a-64-byte-random-secret"
    },
    "anonKey": {
      "value": "replace-me-with-a-stable-anon-key"
    },
    "serviceRoleKey": {
      "value": "replace-me-with-a-stable-service-key"
    },
    "smtpHost": {
      "value": ""
    },
    "smtpUser": {
      "value": ""
    },
    "smtpPassword": {
      "value": ""
    },
    "smtpFrom": {
      "value": "noreply@example.com"
    }
  }
}
